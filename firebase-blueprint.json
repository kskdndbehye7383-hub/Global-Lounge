{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for users.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp of creation" }
      },
      "required": ["email", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A real-time chat message.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["text", "senderId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles. Contains public user data."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Global chat messages."
    }
  }
}
